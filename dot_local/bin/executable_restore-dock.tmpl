#!/bin/zsh
set -euo pipefail

[[ "$(uname -s)" == "Darwin" ]] || exit 0

log() {
  printf '%s\n' "[restore-dock] $*" >&2
}

app_label() {
  local app="$1"
  local plist="$app/Contents/Info.plist"
  local value=""

  for key in CFBundleDisplayName CFBundleName; do
    value="$(/usr/libexec/PlistBuddy -c "Print :$key" "$plist" 2>/dev/null || true)"

    if [[ -n "$value" ]]; then
      printf '%s\n' "$value"
      return 0
    fi
  done

  basename "$app" .app
}

bundle_id() {
  local app="$1"
  local plist="$app/Contents/Info.plist"

  /usr/libexec/PlistBuddy -c "Print :CFBundleIdentifier" "$plist" 2>/dev/null || true
}

app_is_running() {
  local bid="$1"

  if [[ -z "$bid" ]]; then
    printf '%s\n' "unknown"
    return 0
  fi

  /usr/bin/osascript <<APPLESCRIPT 2>/dev/null || true
try
  return application id "$bid" is running
on error
  return "unknown"
end try
APPLESCRIPT
}

quit_app_by_bundle_id() {
  local bid="$1"

  [[ -n "$bid" ]] || return 0

  /usr/bin/osascript <<APPLESCRIPT >/dev/null 2>&1 || true
try
  tell application id "$bid" to quit
end try
APPLESCRIPT
}

find_dockutil() {
  if command -v dockutil >/dev/null 2>&1; then
    command -v dockutil
    return 0
  fi

  for candidate in /opt/homebrew/bin/dockutil /usr/local/bin/dockutil; do
    if [[ -x "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

wait_for_dock() {
  for _ in {1..80}; do
    if pgrep -x Dock >/dev/null 2>&1; then
      return 0
    fi

    sleep 0.25
  done

  return 1
}

wipe_dock_preferences() {
  local dockutil_bin="$1"

  log "wiping Dock layout"

  # Keep recent/running app section enabled.
  # Set this to false if you want no recent-apps section.
  defaults write com.apple.dock show-recents -bool true || true

  # Prefer dockutil for normal Dock cleanup, but also force the plist arrays as fallback.
  if [[ -n "$dockutil_bin" ]]; then
    "$dockutil_bin" --remove all --no-restart >/dev/null 2>&1 || true
  fi

  defaults write com.apple.dock persistent-apps -array || true
  defaults write com.apple.dock persistent-others -array || true
}

current_persistent_dock_labels() {
  /usr/bin/python3 <<'PY'
from pathlib import Path
import plistlib

plist_path = Path.home() / "Library/Preferences/com.apple.dock.plist"

if not plist_path.exists():
    raise SystemExit(0)

with plist_path.open("rb") as f:
    plist = plistlib.load(f)

for item in plist.get("persistent-apps", []):
    tile_data = item.get("tile-data", {})
    label = tile_data.get("file-label")

    if label:
        print(label)
PY
}

live_remove_from_dock() {
  local label="$1"

  log "live-remove: $label"

  DOCK_APP_LABEL="$label" /usr/bin/osascript <<'APPLESCRIPT'
on run
  set appName to system attribute "DOCK_APP_LABEL"

  tell application "System Events"
    tell process "Dock"
      if not (exists UI element appName of list 1) then
        return
      end if

      perform action "AXShowMenu" of UI element appName of list 1
      delay 0.4

      -- German/English direct menu item variants
      try
        click menu item "Remove from Dock" of menu 1 of UI element appName of list 1
        return
      end try

      try
        click menu item "Aus Dock entfernen" of menu 1 of UI element appName of list 1
        return
      end try

      try
        click menu item "Vom Dock entfernen" of menu 1 of UI element appName of list 1
        return
      end try

      -- English Options submenu
      try
        click menu item "Remove from Dock" of menu 1 of menu item "Options" of menu 1 of UI element appName of list 1
        return
      end try

      -- German Optionen submenu
      try
        click menu item "Aus Dock entfernen" of menu 1 of menu item "Optionen" of menu 1 of UI element appName of list 1
        return
      end try

      try
        click menu item "Vom Dock entfernen" of menu 1 of menu item "Optionen" of menu 1 of UI element appName of list 1
        return
      end try
    end tell
  end tell
end run
APPLESCRIPT
}

live_keep_in_dock() {
  local app="$1"
  local label
  local bid
  local was_running

  label="$(app_label "$app")"
  bid="$(bundle_id "$app")"
  was_running="$(app_is_running "$bid")"

  log "live-add: $label ($app)"

  # The app has to be running so its Dock tile exists.
  # -g: do not bring to foreground
  # -j: hide on launch
  /usr/bin/open -gj "$app"

  if ! DOCK_APP_LABEL="$label" /usr/bin/osascript <<'APPLESCRIPT'
on run
  set appName to system attribute "DOCK_APP_LABEL"

  tell application "System Events"
    tell process "Dock"
      repeat 100 times
        if exists UI element appName of list 1 then exit repeat
        delay 0.1
      end repeat

      if not (exists UI element appName of list 1) then
        error "Dock item not found: " & appName
      end if

      perform action "AXShowMenu" of UI element appName of list 1
      delay 0.4

      -- German/English direct menu item variants
      try
        click menu item "Keep in Dock" of menu 1 of UI element appName of list 1
        return
      end try

      try
        click menu item "Im Dock behalten" of menu 1 of UI element appName of list 1
        return
      end try

      try
        click menu item "In Dock behalten" of menu 1 of UI element appName of list 1
        return
      end try

      -- English Options submenu
      try
        click menu item "Keep in Dock" of menu 1 of menu item "Options" of menu 1 of UI element appName of list 1
        return
      end try

      -- German Optionen submenu
      try
        click menu item "Im Dock behalten" of menu 1 of menu item "Optionen" of menu 1 of UI element appName of list 1
        return
      end try

      try
        click menu item "In Dock behalten" of menu 1 of menu item "Optionen" of menu 1 of UI element appName of list 1
        return
      end try

      error "Could not find Keep in Dock menu item for: " & appName
    end tell
  end tell
end run
APPLESCRIPT
  then
    log "warning: AppleScript failed while trying to keep '$label' in Dock"
    return 1
  fi

  # Optional:
  # RESTORE_DOCK_QUIT_STARTED=1 chezmoi apply
  if [[ "${RESTORE_DOCK_QUIT_STARTED:-0}" == "1" && "$was_running" == "false" ]]; then
    log "quit app started only for Dock pinning: $label"
    quit_app_by_bundle_id "$bid"
  fi

  return 0
}

dockutil_bin="$(find_dockutil || true)"

desired_apps=(
{{- range .dock.apps }}
  {{ . | quote }}
{{- end }}
)

installed_apps=()

for app in "${desired_apps[@]}"; do
  expanded="${app/#\~/$HOME}"

  if [[ -d "$expanded" ]]; then
    installed_apps+=("$expanded")
  else
    log "skip missing app: $expanded"
  fi
done

if (( ${#installed_apps[@]} == 0 )); then
  log "none of the configured Dock apps are installed; leaving Dock unchanged"
  exit 0
fi

# Optional delay for login/MDM races.
# Example: DOCK_RESTORE_DELAY=10 chezmoi apply
sleep "${DOCK_RESTORE_DELAY:-0}"

wipe_dock_preferences "$dockutil_bin"

log "restarting Dock so wipe/MDM state becomes visible"
killall Dock >/dev/null 2>&1 || true

if ! wait_for_dock; then
  log "warning: Dock did not appear in time"
fi

# Give MDM/cfprefsd a chance to apply its Dock profile after restart.
sleep "${DOCK_POST_RESTART_DELAY:-2}"

desired_labels=()

for app in "${installed_apps[@]}"; do
  desired_labels+=("$(app_label "$app")")
done

is_desired_label() {
  local candidate="$1"

  for desired in "${desired_labels[@]}"; do
    if [[ "$candidate" == "$desired" ]]; then
      return 0
    fi
  done

  return 1
}

log "removing unmanaged persistent Dock apps via running Dock UI"

while IFS= read -r current_label; do
  [[ -n "$current_label" ]] || continue

  if ! is_desired_label "$current_label"; then
    if ! live_remove_from_dock "$current_label"; then
      log "warning: failed to live-remove $current_label"
    fi
  fi
done < <(current_persistent_dock_labels)

log "adding configured apps to the running Dock via UI automation"

failed=0

for app in "${installed_apps[@]}"; do
  if ! live_keep_in_dock "$app"; then
    log "warning: failed to live-add $app"
    failed=1
  fi
done

if (( failed )); then
  log "finished with warnings"
else
  log "Dock restored live"
fi

log "not restarting Dock afterward, otherwise MDM may wipe it again"

exit "$failed"
